# Runtime catalog and working files
PHOTO_DATA_DIR=/absolute/path/to/photo-manager-data
PHOTO_DATABASE_PATH=/absolute/path/to/photo-manager-data/catalog.db
PHOTO_THUMBNAIL_DIR=/absolute/path/to/photo-manager-data/thumbnails
PHOTO_UPLOAD_DIR=/absolute/path/to/photo-manager-data/uploads
PHOTO_IPHONE_EXPORT_PATH=/absolute/path/to/photo-manager-data/iphone-favorites

# local (default) or s3
PHOTO_STORAGE_BACKEND=local
PHOTO_LOCAL_STORAGE_PATH=/absolute/path/to/photo-manager-data/archive

# S3, Cloudflare R2, or Backblaze B2. boto3 also supports AWS profiles/roles.
PHOTO_S3_BUCKET=
PHOTO_S3_REGION=us-east-1
PHOTO_S3_ENDPOINT_URL=
PHOTO_S3_PREFIX=photo-manager
PHOTO_S3_STORAGE_CLASS=
PHOTO_DERIVATIVE_QUEUE_URL=
# Prefer an assumable local profile instead of putting access keys in this file.
AWS_PROFILE=photo-manager
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Set both before exposing the web app outside localhost.
PHOTO_AUTH_USERNAME=
PHOTO_AUTH_PASSWORD=

# Hosted gallery mode restores the catalog from object storage on first boot,
# snapshots every tagging decision back to object storage, and disables imports.
PHOTO_CLOUD_CATALOG_SYNC=false
PHOTO_HOSTED_GALLERY=false

# Duplicate suggestions at or above this score are grouped automatically.
PHOTO_VARIANT_SUGGEST_THRESHOLD=0.72
PHOTO_VARIANT_CONFIRM_THRESHOLD=0.90
